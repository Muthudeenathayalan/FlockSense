rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User documents with role-based access
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
      
      // Validate user document on create
      allow create: if request.resource.data.keys().hasAll([
        'uid', 'email', 'name', 'role'
      ]) &&
      request.resource.data.email is string &&
      request.resource.data.name is string &&
      request.resource.data.role in ['owner', 'admin', 'viewer'];
      
      // Farm subcollection - owner only
      match /farms/{farmId} {
        allow read, write: if request.auth.uid == uid;
        
        // Validate farm data on create
        allow create: if request.resource.data.keys().hasAll([
          'farmName', 'farmType', 'flockType', 'address', 'birdCapacity'
        ]) &&
        request.resource.data.farmName is string &&
        request.resource.data.farmName.size() >= 2 &&
        request.resource.data.farmName.size() <= 100 &&
        request.resource.data.address is string &&
        request.resource.data.address.size() >= 5 &&
        request.resource.data.birdCapacity is number &&
        request.resource.data.birdCapacity > 0 &&
        request.resource.data.birdCapacity <= 1000000;
        
        // Validate farm data on update
        allow update: if request.resource.data.farmName.size() >= 2 &&
        request.resource.data.farmName.size() <= 100 &&
        request.resource.data.birdCapacity > 0 &&
        request.resource.data.birdCapacity <= 1000000;
        
        // Flock subcollection - scoped to specific farm
        match /flocks/{flockId} {
          allow read, write: if request.auth.uid == uid;
          
          // Validate flock data on create
          allow create: if request.resource.data.keys().hasAll([
            'name', 'birdType', 'farmId', 'openingCount'
          ]) &&
          request.resource.data.farmId == farmId &&
          request.resource.data.openingCount is number &&
          request.resource.data.openingCount > 0;
          
          // Daily records subcollection
          match /daily_records/{recordId} {
            allow read, write: if request.auth.uid == uid;
          }
        }
      }
      
      // Audit logs subcollection - user can only read own logs
      match /audit_logs/{logId} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // Prevent accessing other collections directly
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
